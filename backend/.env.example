# =============================================================================
# .env.example — modelo de configuração (NÃO coloque segredos reais aqui).
# Copie para .env (gitignored) e preencha os valores. Comentários mostram exemplos.
# =============================================================================

# --- Banco de dados (OBRIGATÓRIO) -------------------------------------------
# ex.: postgresql://usuario:senha@host:5432/licenciamento?schema=public
DATABASE_URL=""

# --- Autenticação (OBRIGATÓRIO) ---------------------------------------------
# Gere um segredo forte: openssl rand -hex 32
JWT_SECRET=""
# ex.: 8h
JWT_EXPIRES_IN=""

# --- App (OBRIGATÓRIO) ------------------------------------------------------
# ex.: 3000
PORT=""
# URL pública do sistema (usada em links de e-mail e QR Code)
# ex.: https://licenciamento.cabreuva.sp.gov.br
PUBLIC_URL=""

# --- IA / OCR — Claude (Módulo XII) -----------------------------------------
# Chave da API Anthropic (least-privilege, rotacionável)
ANTHROPIC_API_KEY=""
# ex.: claude-opus-4-8
ANTHROPIC_MODEL=""

# --- E-mail / notificações --------------------------------------------------
# Ordem de envio: Resend (RESEND_API_KEY) → SMTP (SMTP_HOST) → simulado (outbox).
#
# Opção A (recomendada): Resend (https://resend.com) — crie a conta, gere a API key.
# Para enviar a qualquer destinatário é preciso um domínio verificado no Resend;
# para teste, o remetente onboarding@resend.dev entrega ao e-mail dono da conta.
RESEND_API_KEY=""
# Remetente verificado no Resend. ex.: nao-responder@seudominio.com.br (ou onboarding@resend.dev p/ teste)
RESEND_FROM=""
#
# Opção B: SMTP tradicional. Sem RESEND_API_KEY nem SMTP_HOST, e-mails ficam "simulado".
# ex.: smtp.cabreuva.sp.gov.br
SMTP_HOST=""
# ex.: 587
SMTP_PORT=""
# TLS implícito: true ou false
SMTP_SECURE=""
SMTP_USER=""
SMTP_PASS=""
# ex.: nao-responder@cabreuva.sp.gov.br
SMTP_FROM=""

# --- Assinatura digital A1 (ICP-Brasil) — Módulo X --------------------------
# Caminho do certificado .p12/.pfx (mantenha fora do repositório, em certs/).
# Para teste local: rode "npm run gen:cert" e use ./certs/test-a1.p12
SIGN_CERT_PATH=""
SIGN_CERT_PASSWORD=""

# --- Armazenamento de anexos ------------------------------------------------
# "local" (disco) ou "s3" (MinIO/S3)
STORAGE_DRIVER=""
# Usados quando STORAGE_DRIVER=s3
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# --- Autenticação avançada (gov.br / ICP-Brasil) ----------------------------
# Login federado é SIMULADO. Defina "false" em produção para desligá-lo
# até integrar o provedor real (OIDC gov.br / validação ICP).
ALLOW_SIMULATED_SSO=""
